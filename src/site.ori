{
  assets

  (data): airtable.ori/
  // (data): temp.yaml

  images = map(data, {
    key: (person) => person/Image/0/filename
    value: (person) => fetch(person/Image/0/url)
  })

  index.html = index.ori.html(data)

  team = map(data, {
    key: (person, key) => `${ slash/remove(key) }.html`
    value: person.ori.html
  })
}
